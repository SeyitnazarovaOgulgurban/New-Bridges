# 默认底图：天地图栅格（合规·官方来源）+ 克制做旧，见 src/map/tiandituStyle.ts
# 内置「中国古桥」应用 tk（白名单 usst.lyricin.com）。本地 localhost 调试会被白名单拦，
# 需在天地图控制台把 localhost 加入白名单，或换成你自己的 tk：
# VITE_TIANDITU_TK=你的天地图tk

# 可选：若改用 Mapbox 官方底图，填入 pk. 开头 Token（注意国外服务的合规风险）
# VITE_MAPBOX_TOKEN=
# VITE_MAPBOX_WORLDVIEW=CN
# VITE_MAPBOX_LANGUAGE=zh-Hans
# VITE_MAPBOX_STYLE=mapbox://styles/mapbox/light-v11
