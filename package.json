{
    "name": "china-bridge-culture",
    "version": "1.0.0",
    "description": "中国桥梁文化展示网站 - 时空演进与数字档案",
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite --config config/vite.config.ts",
        "build": "vite build --config config/vite.config.ts",
        "preview": "vite preview --config config/vite.config.ts",
        "electron:dev": "electron .",
        "electron:build": "electron-builder --win",
        "dist": "vite build --config config/vite.config.ts && electron-builder --win",
        "sync:bridge-images": "python scripts/sync_bridge_images.py",
        "data:bridge-images": "python scripts/build_bridge_images_json.py",
        "data:bridge-locale": "python scripts/generate_bridge_locales.py"
    },
    "build": {
        "appId": "com.bridge.culture",
        "productName": "ChinaBridgeCulture",
        "directories": {
            "output": "release"
        },
        "asar": false,
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": ["x64"]
                }
            ]
        },
        "portable": {
            "artifactName": "${productName}-${version}.exe"
        }
    },
    "dependencies": {
        "echarts": "^5.5.0",
        "hyperscript": "^2.0.2",
        "mapbox-gl": "^3.3.0",
        "maplibre-gl": "^4.7.1",
        "papaparse": "^5.4.1",
        "sql.js": "^1.14.1"
    },
    "devDependencies": {
        "@types/geojson": "^7946.0.16",
        "@types/hyperscript": "^0.0.7",
        "@types/mapbox-gl": "^3.4.1",
        "@types/node": "^25.0.10",
        "@types/papaparse": "^5.5.2",
        "electron": "^41.2.0",
        "electron-builder": "^26.8.1",
        "terser": "^5.46.1",
        "typescript": "^5.9.3",
        "vite": "^5.4.2",
        "vite-plugin-singlefile": "^2.3.2"
    }
}
